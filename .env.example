# Vortex AI Agents — Environment Variables
# Copy this to .env and fill in your values

# Anthropic API Key — for DARA chat agent
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# IMPORTANT: In production, move the API call to a serverless function
# See /api/chat-proxy.js for the Vercel/Netlify implementation

# Morning Crew waitlist
WAITLIST_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_ID/exec
RESEND_API_KEY=re_YOUR_KEY
PILOT_LIMIT=5
