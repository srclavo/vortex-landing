{
  "redirects": [
    {
      "source": "/mercado/abstorage/demo-site",
      "destination": "/mercado/abstorage/ai-chat/",
      "permanent": true
    },
    {
      "source": "/mercado/abstorage/demo-site/:path*",
      "destination": "/mercado/abstorage/ai-chat/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "abstorage.vortexagents.ai" }],
      "destination": "/abstorage/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "abstorage.vortexagents.ai" }],
      "destination": "/abstorage/$1"
    }
  ]
}
